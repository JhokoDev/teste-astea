rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, institutionId
    //
    // Collection: fairs
    // Fields: name, description, status, organizerId, institutionId, dates
    //
    // Collection: projects
    // Fields: fairId, name, category, abstract, status, studentIds, mentorId, institutionId, score
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "aistudiojhoko@gmail.com" && request.auth.token.email_verified == true) ||
         (request.auth.token.email == "admin@gmail.com"));
    }

    function isSameInstitution(institutionId) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institutionId == institutionId;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'student';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /fairs/{fairId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'organizer');
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (isSameInstitution(resource.data.institutionId) || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isSameInstitution(resource.data.institutionId) || isAdmin());
    }

    match /evaluators/{evaluatorId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'organizer');
    }

    match /institutions/{institutionId} {
      allow read: if isAuthenticated() && (isSameInstitution(institutionId) || isAdmin());
      allow update: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'organizer' && isSameInstitution(institutionId));
      allow create, delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'organizer');
      allow create: if isAuthenticated();
      allow update, delete: if false; // Immutable logs
    }
  }
}
